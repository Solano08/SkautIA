# OpenAI API Key (para el agente Skaut)
OPENAI_API_KEY=

# Mapbox (mapa interactivo de Colombia)
# Crea un token en https://account.mapbox.com/access-tokens/
# IMPORTANTE: pon el valor real en .env.local (Next.js no carga .env.example)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Opcional: clave para datos adicionales
# WORLD_BANK_API no requiere clave - es pública
